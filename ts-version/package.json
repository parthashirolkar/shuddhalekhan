{
  "name": "ts-version",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/index.ts --compile --windows-icon=./tray-icon.ico --outfile speech-to-text.exe",
    "build:gui": "bun build src/index.ts --compile --windows-icon=./tray-icon.ico --windows-hide-console --outfile speech-to-text.exe",
    "build:headless": "bun build src/index.ts --compile --windows-icon=./tray-icon.ico --outfile speech-to-text.exe && powershell -ExecutionPolicy Bypass -NoProfile -File build-headless.ps1",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/form-data": "^2.5.2",
    "@types/node": "^25.0.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@langchain/community": "^1.1.21",
    "@langchain/core": "^1.1.29",
    "@langchain/ollama": "^1.2.5",
    "@winput/keyboard": "^1.0.11",
    "form-data": "^4.0.5",
    "koffi": "^2.15.0",
    "langchain": "^1.2.28",
    "node-cpal": "^0.1.1",
    "systray2": "^2.1.4",
    "zod": "^4.3.6"
  }
}
