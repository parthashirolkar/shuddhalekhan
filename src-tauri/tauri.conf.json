{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Speech-2-Text",
  "version": "2.3.0",
  "identifier": "com.speech2text.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Speech-2-Text",
        "width": 400,
        "height": 300,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true
      },
      {
        "label": "recording",
        "title": "Recording",
        "width": 102,
        "height": 46,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focusable": false,
        "shadow": false
      },
      {
        "label": "approval",
        "title": "Approval",
        "width": 520,
        "height": 400,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "resizable": false,
        "center": true
      },
      {
        "label": "agent-response",
        "title": "Jarvis Response",
        "width": 420,
        "height": 120,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^.*powershell.*$"
    },
    "updater": {
      "endpoints": [
        "https://github.com/parthashirolkar/shuddhalekhan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3OUQ2ODA3NTYwODgyMTgKUldRWWdnaFdCMmlkTjJtZGt1Tk9aWXBHR08yZXl0QXMwQncxYStIcTU0eHV1MmkvWkFHQmlCWTQK"
    }
  }
}

